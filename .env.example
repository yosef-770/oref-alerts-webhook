# Telegram Bot Configuration
# Get bot token from @BotFather on Telegram
TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTuVwXyZ-1234567890

# Telegram Chat ID where alerts will be sent
# Use @userinfobot to get your chat ID, or for groups: add bot and use negative ID
TELEGRAM_CHAT_ID=-1001234567890

# Legacy webhook URL (optional - for backward compatibility)
# Only needed if using old single-webhook configuration
WEBHOOK_URL=https://your-external-server.com/webhook-endpoint

# Generic API token for custom endpoints
API_TOKEN=your_super_secret_token_here

# Discord webhook URL (can be embedded directly in config.json)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/1234567890/ABCdefGhIJKlmNoPQRsTuVwXyZ-1234567890-ABCdefGhIJKlmNoPQRsTuVwXyZ
